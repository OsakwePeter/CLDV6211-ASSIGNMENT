@{
    ViewData["Title"] = "Dashboard";
}

<div class="hero">
    <h1>Welcome to <span class="accent">EventEase</span></h1>
    <p>Plan smart. Book fast. Celebrate without conflict.</p>
    <div>
        <a href="/Venue" class="btn-hero">Venues</a>
        <a href="/Event" class="btn-hero">Events</a>
        <a href="/Booking" class="btn-hero">Bookings</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <a href="/Venue" class="stat-card">
            <span class="stat-icon">🏛️</span>
            <div class="stat-number">Venues</div>
            <div class="stat-label">Browse &amp; manage all venue spaces</div>
            <span class="stat-link">View All &rsaquo;</span>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Event" class="stat-card">
            <span class="stat-icon">📅</span>
            <div class="stat-number">Events</div>
            <div class="stat-label">Create &amp; schedule upcoming events</div>
            <span class="stat-link">View All &rsaquo;</span>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Booking" class="stat-card">
            <span class="stat-icon">🎟️</span>
            <div class="stat-number">Bookings</div>
            <div class="stat-label">Track all reservations &amp; assignments</div>
            <span class="stat-link">View All &rsaquo;</span>
        </a>
    </div>
</div>
