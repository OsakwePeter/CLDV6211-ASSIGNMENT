@model EventEase.Models.Venue
@{ ViewData["Title"] = "Delete Venue"; }

<h1>Delete Venue</h1>

@if ((bool)ViewBag.HasBookings)
{
    <div class="alert alert-danger" role="alert">
        <strong>✗ Cannot delete this venue.</strong>
        This venue has <strong>@ViewBag.BookingCount active booking(s)</strong> associated with it.
        You must cancel all bookings for this venue before it can be deleted.
        <br /><a asp-controller="Booking" asp-action="Index" class="alert-link">Go to Bookings →</a>
    </div>
}
else
{
    <div class="alert alert-warning" role="alert">
        <strong>⚠ Are you sure?</strong> This action cannot be undone.
        The venue image stored in Azurite will also be permanently deleted.
    </div>
}

<div class="form-card">
    <dl class="row">
        <dt class="col-sm-3">Venue Name</dt>
        <dd class="col-sm-9">@Model.VenueName</dd>
        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Location</dd>
        <dt class="col-sm-3">Capacity</dt>
        <dd class="col-sm-9">@Model.Capacity.ToString("N0") guests</dd>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <dt class="col-sm-3">Image</dt>
            <dd class="col-sm-9">
                <img src="@Model.ImageUrl" alt="@Model.VenueName"
                     style="max-height:120px; border-radius:6px; border:1px solid #ddd;" />
            </dd>
        }
    </dl>

    <div class="d-flex gap-2">
        @if (!(bool)ViewBag.HasBookings)
        {
            <form asp-action="Delete">
                <input type="hidden" asp-for="VenueID" />
                <button type="submit" class="btn btn-danger">Yes, Delete Venue</button>
            </form>
        }
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</div>
