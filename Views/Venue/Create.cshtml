@model EventEase.Models.Venue
@{ ViewData["Title"] = "Add Venue"; }

<h1>Add New Venue</h1>
<div class="form-card">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="VenueName" class="form-label">Venue Name <span class="text-danger">*</span></label>
            <input asp-for="VenueName" class="form-control" placeholder="e.g. Grand Ballroom" />
            <span asp-validation-for="VenueName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Location" class="form-label">Location <span class="text-danger">*</span></label>
            <input asp-for="Location" class="form-control" placeholder="e.g. 12 Main Street, Sandton" />
            <span asp-validation-for="Location" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Capacity" class="form-label">Capacity <span class="text-danger">*</span></label>
            <input asp-for="Capacity" class="form-control" type="number" min="1" placeholder="e.g. 300" />
            <span asp-validation-for="Capacity" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ImageFile" class="form-label">
                Venue Image
                <span class="text-muted fw-normal small">(optional &mdash; max 5 MB, JPG/PNG/WEBP/GIF)</span>
            </label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
            <div class="form-text">Image will be stored in Azurite local blob storage (venue-images container).</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Venue</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
