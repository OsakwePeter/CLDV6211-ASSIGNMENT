@model EventEase.Models.Venue
@{ ViewData["Title"] = "Add Venue"; }

<h1>Add New Venue</h1>
<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="mb-3">
            <label asp-for="VenueName" class="form-label">Venue Name</label>
            <input asp-for="VenueName" class="form-control" placeholder="e.g. Grand Ballroom" />
            <span asp-validation-for="VenueName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Location" class="form-label">Location</label>
            <input asp-for="Location" class="form-control" placeholder="e.g. 12 Main Street, Lagos" />
            <span asp-validation-for="Location" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Capacity" class="form-label">Capacity</label>
            <input asp-for="Capacity" class="form-control" placeholder="e.g. 300" />
            <span asp-validation-for="Capacity" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="ImageUrl" class="form-label">Image URL <span class="text-muted fw-normal">(optional)</span></label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Venue</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
