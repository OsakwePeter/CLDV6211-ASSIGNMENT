@model EventEase.Models.Booking
@{ ViewData["Title"] = "New Booking"; }

<h1>New Booking</h1>
<div class="form-card">
    <form asp-action="Create">

        @* Prominent validation summary — shows double-booking and other model errors *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" role="alert">
                <strong>✗ Please fix the following errors:</strong>
                <div asp-validation-summary="ModelOnly" class="mt-1 mb-0"></div>
            </div>
        }

        <div class="mb-3">
            <label asp-for="EventID" class="form-label">Event <span class="text-danger">*</span></label>
            <select asp-for="EventID" class="form-select"
                    asp-items="@(new SelectList(ViewData["Events"] as IEnumerable<EventEase.Models.Event>, "EventID", "EventName"))">
                <option value="">-- Select an Event --</option>
            </select>
            <span asp-validation-for="EventID" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="VenueID" class="form-label">Venue <span class="text-danger">*</span></label>
            <select asp-for="VenueID" class="form-select"
                    asp-items="@(new SelectList(ViewData["Venues"] as IEnumerable<EventEase.Models.Venue>, "VenueID", "VenueName"))">
                <option value="">-- Select a Venue --</option>
            </select>
            <span asp-validation-for="VenueID" class="text-danger small"></span>
            <div class="form-text">
                ⚠ The system will automatically prevent double-booking of a venue on the same date.
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Confirm Booking</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
