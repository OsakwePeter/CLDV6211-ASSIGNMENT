@model IEnumerable<EventEase.Models.Event>
@{ ViewData["Title"] = "Events"; }

<div class="page-heading">
    <div class="page-heading-left">
        <h1>Events</h1>
        <p class="page-subtitle">All scheduled &amp; upcoming events</p>
    </div>
    <a asp-action="Create" class="btn-add">＋ Add Event</a>
</div>

@* ── Alert messages ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✓</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>✗</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>⚠</strong> @TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-card">
    <table class="table">
        <thead>
            <tr>
                <th>Image</th>
                <th>Event Name</th>
                <th>Date &amp; Time</th>
                <th>Venue</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                    ? "https://placehold.co/80x56/1A1A30/D4AF37?text=Event"
                                    : item.ImageUrl)"
                             alt="@item.EventName"
                             class="venue-thumb"
                             onerror="this.src='https://placehold.co/80x56/1A1A30/D4AF37?text=Event'" />
                    </td>
                    <td><strong>@item.EventName</strong></td>
                    <td>
                        @item.EventDate.ToString("dd MMM yyyy")
                        <br /><small class="text-muted">@item.EventDate.ToString("HH:mm")</small>
                    </td>
                    <td>
                        @if (item.Venue != null)
                        {
                            <span>@item.Venue.VenueName</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Unassigned</span>
                        }
                    </td>
                    <td>
                        <small class="text-muted">
                            @(item.Description?.Length > 55
                                ? item.Description.Substring(0, 55) + "…"
                                : item.Description)
                        </small>
                    </td>
                    <td>
                        <div class="btn-action-group">
                            <a asp-action="Edit"    asp-route-id="@item.EventID" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.EventID" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Delete"  asp-route-id="@item.EventID" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; padding: 3rem; color: var(--text-muted);">
                        No events yet. <a asp-action="Create" style="color:var(--gold);">Create the first one →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
