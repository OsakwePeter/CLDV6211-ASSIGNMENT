@model EventEase.Models.Event
@{ ViewData["Title"] = "Add Event"; }

<h1>Add New Event</h1>
<div class="form-card">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="EventName" class="form-label">Event Name <span class="text-danger">*</span></label>
            <input asp-for="EventName" class="form-control" placeholder="e.g. Annual Gala Dinner" />
            <span asp-validation-for="EventName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventDate" class="form-label">Date &amp; Time <span class="text-danger">*</span></label>
            <input asp-for="EventDate" class="form-control" type="datetime-local" />
            <span asp-validation-for="EventDate" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">
                Description <span class="text-muted fw-normal small">(optional)</span>
            </label>
            <textarea asp-for="Description" class="form-control" rows="3"
                      placeholder="Brief description of the event..."></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="VenueID" class="form-label">
                Venue <span class="text-muted fw-normal small">(optional &mdash; can be assigned later)</span>
            </label>
            <select asp-for="VenueID" class="form-select"
                    asp-items="@(new SelectList(ViewData["Venues"] as IEnumerable<EventEase.Models.Venue>, "VenueID", "VenueName"))">
                <option value="">-- No venue assigned yet --</option>
            </select>
        </div>

        <div class="mb-4">
            <label asp-for="ImageFile" class="form-label">
                Event Image
                <span class="text-muted fw-normal small">(optional &mdash; max 5 MB, JPG/PNG/WEBP/GIF)</span>
            </label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
            <div class="form-text">Image will be stored in Azurite local blob storage (venue-images container).</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Event</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
